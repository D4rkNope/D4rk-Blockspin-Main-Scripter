local function CreateToggleButton(a, b)
	if type(a) ~= "string" then
		error("Image Error", 2)
	end
	if type(b) ~= "function" then
		error("Callback Error", 2)
	end
	if getgenv().OpenGuiButton then
		getgenv().OpenGuiButton:Destroy()
	end

	local c = Instance.new("ScreenGui")
	local d = Instance.new("Frame")
	local e = Instance.new("UICorner")
	local f = Instance.new("ImageButton")
	local g = Instance.new("UICorner")

	c.Parent = (gethui and gethui()) or game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")
	c.Name = "ToggleButtonUI"
	
	d.Parent = c
	d.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	d.BackgroundTransparency = 0.5
	d.BorderColor3 = Color3.fromRGB(0, 0, 0)
	d.BorderSizePixel = 0
	d.Position = UDim2.new(0.491, 0, 0, 65)
	d.Size = UDim2.new(0, 44, 0, 44)

	e.Parent = d

	f.Parent = d
	f.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	f.BackgroundTransparency = 1
	f.BorderColor3 = Color3.fromRGB(0, 0, 0)
	f.BorderSizePixel = 0
	f.Position = UDim2.new(0, 0, 0, 0)
	f.Size = UDim2.new(1, 0, 1, 0)
	f.Image = a

	g.Parent = f

	local uis = game:GetService("UserInputService")
	local ts = game:GetService("TweenService")
	local isDragging = false
	local dragTolerance = 6
	local dragStart = nil
	local startPos = nil
	local hasMoved = false
	local isToggled = false

	task.defer(function()
		local absPos = d.AbsolutePosition
		d.AnchorPoint = Vector2.new(0.5, 0.5)
		d.Position = UDim2.new(0, absPos.X + 22, 0, absPos.Y + 22)
	end)

	f.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			isDragging = true
			hasMoved = false
			dragStart = input.Position
			startPos = d.Position
			ts:Create(d, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(0, 36, 0, 36)}):Play()
		end
	end)

	uis.InputChanged:Connect(function(input)
		if not isDragging then return end
		if input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch then return end
		local delta = input.Position - dragStart
		if not hasMoved then
			if math.abs(delta.X) < dragTolerance and math.abs(delta.Y) < dragTolerance then return end
			hasMoved = true
		end
		ts:Create(d, TweenInfo.new(0.13, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Position = UDim2.new(0, startPos.X.Offset + delta.X, 0, startPos.Y.Offset + delta.Y)
		}):Play()
	end)

	uis.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			isDragging = false
			ts:Create(d, TweenInfo.new(0.1, Enum.EasingStyle.Bounce, Enum.EasingDirection.Out), {Size = UDim2.new(0, 44, 0, 44)}):Play()
		end
	end)

	f.MouseButton1Click:Connect(function()
		if hasMoved then return end
		isToggled = not isToggled
		ts:Create(d, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Rotation = isToggled and 180 or 0}):Play()
		b()
	end)

	getgenv().OpenGuiButton = c
	return c
end

CreateToggleButton("rbxassetid://100795522583377", function()
	Window:Toggle()
end)
